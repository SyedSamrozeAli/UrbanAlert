<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <link rel="stylesheet" href="/styles/login-page.css" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://unpkg.com/aos@next/dist/aos.css" />
    <link
      href="https://fonts.googleapis.com/css2?family=Syne:wght@400..800&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Baloo+Chettan+2:wght@400..800&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@100..900&display=swap"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css"
    />
    <title>UrbanAlert</title>

    <style>
      .form-container {
        gap: 80px;
      }

      .input-box {
        position: relative;
      }

      .input-box input {
        width: 100%;
      }
      form {
        width: 40vw;
        gap: 30px;
      }
      form button {
        width: 100%;
      }
    </style>
  </head>
  <body>
    <div class="shadow-1"></div>
    <div class="shadow-2"></div>
    <div
      class="form-container"
      data-aos="fade-in"
      data-aos-offset="200"
      data-aos-delay="0"
      data-aos-duration="1000"
      data-aos-easing="ease"
    >
      <div class="heading">
        <h1>Urban <br /><span style="visibility: hidden">i</span> Alert</h1>
      </div>
      <h2>Login to to your Account</h2>
      <form action="/user/login" method="POST">
        <div class="input-box">
          <input type="email" name="email" required />
          <label>E-mail</label>
        </div>
        <div class="input-box">
          <input type="password" name="password" required />
          <label>Password</label>
        </div>

        <button type="submit">Login</button>
        <% if(locals.successMsg){ %>
        <p style="color: #606c38"><i><%= locals.successMsg %></i></p>
        <% } if(locals.err_msg){ %>
        <p style="color: red"><i><%= err_msg %></i></p>
        <% } %>
      </form>
      <div class="social-login">
        <button class="facebook-btn">
          <i class="fab fa-facebook"></i> Login with Facebook
        </button>
        <button class="google-btn">
          <i class="fab fa-google"></i> Login with Gmail
        </button>
      </div>
    </div>
    <div
      class="side-container"
      data-aos="slide-left"
      data-aos-offset="200"
      data-aos-delay="100"
      data-aos-duration="1000"
      data-aos-easing="ease"
    >
      <h2>Report, Resolve, Revitalize</h2>
    </div>
    <script src="https://unpkg.com/aos@next/dist/aos.js"></script>
    <script>
      AOS.init();
    </script>
  </body>
</html>
